                "managerId"
              ],
              "properties": {
                "newHireId": {
                  "type": "string",
                  "x-ms-summary": "New hire id"
                },
                "startDate": {
                  "type": "string",
                  "x-ms-summary": "Start date"
                },
                "managerId": {
                  "type": "string",
                  "x-ms-summary": "Manager id"
                },
                "buddyId": {
                  "type": "string",
                  "x-ms-summary": "Buddy id"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/OnboardingPlan"
            }
          },
          "404": {
            "description": "Employee not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/onboarding/{planId}": {
      "get": {
        "operationId": "getOnboarding",
        "summary": "Get onboarding plan",
        "x-ms-summary": "Get onboarding plan",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "planId",
            "in": "path",
            "required": true,
