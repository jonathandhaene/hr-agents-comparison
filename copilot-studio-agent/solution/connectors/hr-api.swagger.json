        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {
                "matches": {
                  "type": "array",
                  "x-ms-summary": "Matches",
                  "items": {
                    "$ref": "#/definitions/Job"
                  }
                }
              }
            }
          }
        }
      }
    },
