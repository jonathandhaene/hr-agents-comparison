            }
          }
        }
      }
    },
    "/onboarding/{planId}/task/{taskId}/status": {
      "post": {
        "operationId": "setOnboardingTaskStatus",
        "summary": "Set onboarding task status",
        "x-ms-summary": "Set onboarding task status",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "planId",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Plan id"
          },
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Task id"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "status"
              ],
              "properties": {
                "status": {
                  "type": "string",
                  "x-ms-summary": "Status",
                  "enum": [
                    "not-started",
                    "in-progress",
                    "done",
                    "overdue"
                  ]
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {
                "ok": {
                  "type": "boolean"
                },
                "plan": {
                  "$ref": "#/definitions/OnboardingPlan"
                }
              }
            }
          },
          "404": {
            "description": "Plan or task not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/jobs/search": {
      "post": {
        "operationId": "searchJobs",
        "summary": "Search internal jobs",
        "x-ms-summary": "Search internal jobs",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "employeeId"
              ],
              "properties": {
                "employeeId": {
                  "type": "string",
                  "x-ms-summary": "Employee id"
                },
                "interests": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "x-ms-summary": "Interests"
                },
                "location": {
                  "type": "string",
                  "x-ms-summary": "Preferred location"
                }
              }
            }
          }
