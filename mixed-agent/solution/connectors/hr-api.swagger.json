    "/onboarding/{id}/tick": {
      "post": {
        "operationId": "tickOnboarding",
        "summary": "Tick onboarding plan",
        "description": "Idempotent daily tick that advances the plan and emits reminders for due tasks.",
        "x-ms-summary": "Tick onboarding plan",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Plan id"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {
                "planId": {
                  "type": "string"
                },
                "advanced": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "dueTasks": {
                  "type": "array",
                  "x-ms-summary": "Due tasks",
                  "items": {
                    "$ref": "#/definitions/DueTask"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Plan not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
