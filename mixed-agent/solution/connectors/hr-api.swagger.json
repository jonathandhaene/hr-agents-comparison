{
  "swagger": "2.0",
  "info": {
    "title": "Contoso HR API (mixed)",
    "version": "1.1.0",
    "description": "Custom Connector to the Azure Functions HR API. Auth: function key in the x-functions-key header (rotate via Functions host configuration). Field names and response shapes match the Functions backend exactly."
  },
  "host": "${HR_API_HOST}",
  "basePath": "/api",
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "functionKey": {
      "type": "apiKey",
      "in": "header",
      "name": "x-functions-key"
    }
  },
  "security": [
    {
      "functionKey": []
    }
  ],
  "paths": {
    "/employees/{id}": {
      "get": {
        "operationId": "getEmployee",
        "summary": "Get employee",
        "x-ms-summary": "Get employee",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Employee id or email"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/Employee"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/employees/byName": {
      "get": {
        "operationId": "findEmployeesByName",
        "summary": "Find employees by name",
        "x-ms-summary": "Find employees by name",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "type": "string",
            "x-ms-summary": "Full or partial name"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {
                "matches": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/EmployeeRef"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/employees/byPersona": {
      "get": {
        "operationId": "findEmployeeByPersona",
        "summary": "Find employee by persona",
        "x-ms-summary": "Find employee by persona",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "persona",
            "in": "query",
            "required": true,
            "type": "string",
            "x-ms-summary": "Persona"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/EmployeeRef"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/leave/request": {
      "post": {
        "operationId": "requestLeave",
        "summary": "Request leave",
        "description": "Idempotent on Idempotency-Key. Returns the full request including the resolved managerId and computed day count.",
        "x-ms-summary": "Request leave",
        "x-ms-visibility": "important",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "type": "string",
            "x-ms-summary": "Idempotency key",
            "x-ms-visibility": "advanced"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "employeeId",
                "startDate",
                "endDate"
              ],
              "properties": {
                "employeeId": {
                  "type": "string",
                  "x-ms-summary": "Employee id"
                },
                "startDate": {
                  "type": "string",
                  "x-ms-summary": "Start date (yyyy-mm-dd)"
                },
                "endDate": {
                  "type": "string",
                  "x-ms-summary": "End date (yyyy-mm-dd)"
                },
                "type": {
                  "type": "string",
                  "x-ms-summary": "Leave type",
                  "default": "vacation",
                  "enum": [
                    "vacation",
                    "sick",
                    "personal"
                  ]
                },
                "note": {
                  "type": "string",
                  "x-ms-summary": "Note",
                  "x-ms-visibility": "advanced"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/LeaveRequest"
            }
          },
          "200": {
            "description": "OK (replay)",
            "schema": {
              "$ref": "#/definitions/LeaveRequest"
            }
          },
          "400": {
            "description": "Validation error",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          },
          "404": {
            "description": "Employee not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/leave/{id}/approve": {
      "post": {
        "operationId": "approveLeave",
        "summary": "Approve leave",
        "x-ms-summary": "Approve leave",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Leave request id"
          },
          {
            "name": "body",
            "in": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/Decision"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/LeaveRequest"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          },
          "409": {
            "description": "Conflicting state",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/leave/{id}/reject": {
      "post": {
        "operationId": "rejectLeave",
        "summary": "Reject leave",
        "x-ms-summary": "Reject leave",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "x-ms-summary": "Leave request id"
          },
          {
            "name": "body",
            "in": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/Decision"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/LeaveRequest"
            }
          },
          "404": {
            "description": "Not found",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          },
          "409": {
            "description": "Conflicting state",
            "schema": {
              "$ref": "#/definitions/Problem"
            }
          }
        }
      }
    },
    "/onboarding/start": {
      "post": {
        "operationId": "startOnboarding",
        "summary": "Start onboarding",
