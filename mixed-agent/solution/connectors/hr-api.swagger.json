    "/feedback/raw": {
      "post": {
        "operationId": "getFeedbackRaw",
        "summary": "Get raw feedback",
        "description": "Returns reviewer answers for the connected Foundry agent to summarise. Sensitive; do not log responses verbatim.",
        "x-ms-summary": "Get raw feedback",
        "x-ms-visibility": "advanced",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "required": [
                "requestId"
              ],
              "properties": {
                "requestId": {
                  "type": "string",
                  "x-ms-summary": "Feedback request id"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "object",
              "properties": {
                "requestId": {
                  "type": "string"
                },
                "responses": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "reviewerId": {
                        "type": "string"
                      },
                      "answers": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
