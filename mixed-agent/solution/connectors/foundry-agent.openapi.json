{
  "openapi": "3.0.1",
  "info": {"title": "Foundry connected agent", "version": "1.0.0", "description": "Calls a Microsoft Foundry hosted agent. Auth: managed identity via the Foundry data action."},
  "servers": [{"url": "${FOUNDRY_PROJECT_ENDPOINT}"}],
  "paths": {
    "/agents/{agentName}/invoke": {
      "post": {
        "operationId": "invokeAgent",
        "parameters": [{"name": "agentName", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "properties": {"input": {"type": "string"}, "context": {"type": "object"}}}}}
        },
        "responses": {"200": {"description": "OK", "content": {"application/json": {"schema": {"type": "object", "properties": {"message": {"type": "string"}, "citations": {"type": "array", "items": {"type": "object"}}}}}}}}
      }
    }
  },
  "components": {"securitySchemes": {"managedIdentity": {"type": "oauth2", "flows": {"clientCredentials": {"tokenUrl": "https://login.microsoftonline.com/${TENANT_ID}/oauth2/v2.0/token", "scopes": {}}}}}},
  "security": [{"managedIdentity": []}]
}
